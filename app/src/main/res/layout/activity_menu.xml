<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MenuActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="15dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="307dp"
                android:layout_height="150dp"
                app:srcCompat="@drawable/mcdoologo" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="180dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_marginStart="700dp"
                android:backgroundTint="@color/white"
                android:backgroundTintMode="src_over"
                android:text="@string/log_out"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                app:iconGravity="textStart"
                app:iconPadding="15dp"
                app:iconTint="@null"
                app:strokeColor="@color/black"
                app:strokeWidth=".75dp" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSales"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:backgroundTint="@color/white"
                android:backgroundTintMode="src_over"
                android:text="@string/sales"
                android:textColor="@color/black"
                android:textSize="40sp"
                app:cornerRadius="50dp"
                app:strokeColor="#CEC9C9"
                app:strokeWidth="10dp" />

            <Button
                android:id="@+id/btnOrders"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:layout_marginRight="50dp"
                android:backgroundTint="@color/white"
                android:backgroundTintMode="src_over"
                android:text="@string/orders"
                android:textColor="@color/black"
                android:textSize="40sp"
                app:cornerRadius="50dp"
                app:strokeColor="#CEC9C9"
                app:strokeWidth="10dp" />

            <Button
                android:id="@+id/btnInventory"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:backgroundTint="@color/white"
                android:backgroundTintMode="src_over"
                android:text="@string/orders"
                android:textColor="@color/black"
                android:textSize="40sp"
                app:cornerRadius="50dp"
                app:strokeColor="#CEC9C9"
                app:strokeWidth="10dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="50dp">

            <Button
                android:id="@+id/btnEmployees"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:backgroundTint="@color/white"
                android:backgroundTintMode="src_over"
                android:text="@string/employees"
                android:textColor="@color/black"
                android:textSize="40sp"
                app:cornerRadius="50dp"
                app:strokeColor="#CEC9C9"
                app:strokeWidth="10dp"
                android:layout_marginRight="50dp"
                android:layout_marginLeft="50dp"/>

            <Button
                android:id="@+id/btnAudit"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:backgroundTint="@color/white"
                android:backgroundTintMode="src_over"
                android:text="@string/audit"
                android:textColor="@color/black"
                android:textSize="40sp"
                app:cornerRadius="50dp"
                app:strokeColor="#CEC9C9"
                app:strokeWidth="10dp"
                android:layout_marginRight="50dp"/>

            <Button
                android:id="@+id/btnReports"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:backgroundTint="@color/white"
                android:backgroundTintMode="src_over"
                android:text="@string/reports"
                android:textColor="@color/black"
                android:textSize="40sp"
                app:cornerRadius="50dp"
                app:strokeColor="#CEC9C9"
                app:strokeWidth="10dp"
                />


        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>